          },
          "emContact": {
            "minLength": 1,
            "type": "string"
          },
          "emMail": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "emDistrict": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
